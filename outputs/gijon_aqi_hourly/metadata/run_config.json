  "arima_max_p": 3,
  "arima_max_d": 1,
  "arima_max_q": 3,
  "varma_max_p": 2,
  "varma_max_q": 1,
  "varma_use_weather_exog": false,
  "svmr_train_limit": 0,
  "mlp_max_iter": 500,
  "n_jobs": 1
}